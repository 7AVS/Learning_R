/* =====================================================================
   AU-ADD RESPONSE — VINTAGE CURVE (0–30 days), by Test/Control,
   strategy arm and model arm.
   Success = an authorized user was actually added within 30 days of
   treatment. Read from the event table, not an ownership snapshot.
   ===================================================================== */

WITH
/* 0–30 day spine. I cross join this later so every segment gets a row
   for every vintage day — even days with zero adds — so the cumulative
   curve is continuous instead of skipping empty days. */
vintage_days AS (
    SELECT (calendar_date - DATE '2000-01-01') AS vintage_day
    FROM sys_calendar.calendar
    WHERE calendar_date BETWEEN DATE '2000-01-01' AND DATE '2000-01-01' + 30
),

/* CAMPAIGN POPULATION. The tactic table is the universe of everyone in
   the campaign; tactic_id pins it to this one. I decode tst_grp_cd into
   the experiment cells and set day 0 = treatmt_strt_dt. */
cohort AS (
    SELECT
        clnt_no,
        CAST(TACTIC_EVNT_ID AS BIGINT) AS acct_no,   -- account key
        treatmt_strt_dt,                             -- vintage day 0
        treatmt_end_dt,                              -- end of attribution window
        tst_grp_cd,
        CASE WHEN RIGHT(trim(tst_grp_cd),2)='_C' THEN 'Control' ELSE 'Test' END AS test_group, -- _C = held-out control
        treatmt_strt_dt AS wave_dt,
        CASE WHEN SUBSTR(tst_grp_cd,1,3) IN ('NRR','NRM','NRW') THEN 'NonReward'        -- first 3 chars = offer strategy
             WHEN SUBSTR(tst_grp_cd,1,3) IN ('RNR','RNM','RNW') THEN 'Rewards_No_Offer'
             WHEN SUBSTR(tst_grp_cd,1,3) IN ('ROR','ROM','ROW') THEN 'Rewards_Offer'
             ELSE 'Unknown' END AS strategy_arm,
        CASE WHEN SUBSTR(tst_grp_cd,3,1)='R' THEN 'Random'   -- 3rd char = how they were selected into the cell
             WHEN SUBSTR(tst_grp_cd,3,1)='M' THEN 'Model'
             WHEN SUBSTR(tst_grp_cd,3,1)='W' THEN 'Web'
             ELSE 'Unknown' END AS model_arm,
        substr(tactic_decisn_vrb_info,21,3) AS prod_cd       -- product I offered, parsed from the decision string
    FROM DG6V01.tactic_evnt_ip_ar_hist
    WHERE tactic_id='2026119AUH'
),

/* SUCCESS EVENT. I read the real "authorized user added" event, NOT an
   ownership snapshot. The ownership delta table mislead me earlier:
   CHG_DT is only an end/change marker and captr_dt is a snapshot date,
   so the current-record approach counted long-time holders whose row was
   merely re-touched after the campaign. The event table fires only when
   the add actually happens, and evnt_dt is the true acquisition date.
     dtl_evnt_typ_cd = 191 -> "user added"
     ADD_RELTN_CD    = 3   -> authorized-user indicator
   Product comes from the portfolio (visa_prod_cd). No product allow-list
   on purpose, so a conversion to ANY product is detectable. */
au_event AS (
    SELECT a.acct_no, c.visa_prod_cd AS prod_cd, a.evnt_dt
    FROM D3CV12A.CR_CRD_ACCT_EVNT_DLY a
    INNER JOIN D3CV12A.DLY_FULL_PORTFOLIO c
        ON a.clnt_no = c.clnt_no
       AND a.evnt_dt = c.DT_RECORD_EXT
       AND a.acct_no = c.acct_no
    WHERE a.dtl_evnt_typ_cd = 191
      AND a.ADD_RELTN_CD  = 3
),

/* Earliest add per account+product. MIN(evnt_dt) = first genuine
   acquisition, so repeat adds don't double-count and pre-existing
   holders drop out once I window on treatment dates below. */
new_owner AS (
    SELECT acct_no, prod_cd, MIN(evnt_dt) AS first_owned_dt
    FROM au_event
    GROUP BY acct_no, prod_cd
),

/* Denominators. COUNT(DISTINCT acct_no) — one account once, never
   count(*), so duplicate leads can't inflate the base. */
pop_sm AS (   -- by strategy + model + test/control
    SELECT wave_dt,strategy_arm,model_arm,test_group,COUNT(DISTINCT acct_no) AS total_population
    FROM cohort GROUP BY 1,2,3,4
),
pop_s AS (    -- rolled up across model (for the Overall line)
    SELECT wave_dt,strategy_arm,test_group,COUNT(DISTINCT acct_no) AS total_population
    FROM cohort GROUP BY 1,2,3
),

/* ATTRIBUTION. Join success back to the campaign on the account and keep
   only events INSIDE that account's treatment window — this is what ties
   the add to the campaign and excludes anyone who already held it.
     first_app_dt        = earliest add to ANY product
     first_app_dt_target = earliest add to the product I actually offered */
success_events AS (
    SELECT c.wave_dt,c.strategy_arm,c.model_arm,c.test_group,c.acct_no,c.treatmt_strt_dt,
        MIN(n.first_owned_dt) AS first_app_dt,
        MIN(CASE WHEN trim(c.prod_cd)=trim(n.prod_cd) THEN n.first_owned_dt END) AS first_app_dt_target
    FROM cohort c
    INNER JOIN new_owner n
        ON n.acct_no=c.acct_no
       AND n.first_owned_dt BETWEEN c.treatmt_strt_dt AND c.treatmt_end_dt
    GROUP BY 1,2,3,4,5,6
),

/* Daily counts, bucketed by vintage day (= add date − day 0), capped
   0–30 so this stays a strict 30-day response measure. */
resp_d AS (   -- any-product success
    SELECT wave_dt,strategy_arm,model_arm,test_group,
        (first_app_dt-treatmt_strt_dt) AS vintage_day,COUNT(DISTINCT acct_no) AS responders
    FROM success_events WHERE (first_app_dt-treatmt_strt_dt) BETWEEN 0 AND 30
    GROUP BY 1,2,3,4,5
),
resp_t AS (   -- target-product success only
    SELECT wave_dt,strategy_arm,model_arm,test_group,
        (first_app_dt_target-treatmt_strt_dt) AS vintage_day,COUNT(DISTINCT acct_no) AS responders_target
    FROM success_events
    WHERE first_app_dt_target IS NOT NULL AND (first_app_dt_target-treatmt_strt_dt) BETWEEN 0 AND 30
    GROUP BY 1,2,3,4,5
),

/* Lay population + both responder streams onto the full 0–30 grid.
   CROSS JOIN guarantees a row per day; COALESCE fills no-add days with 0
   so the curve never breaks. */
detailed_by_model AS (
    SELECT p.wave_dt,p.strategy_arm,p.model_arm,p.test_group,v.vintage_day,p.total_population,
        COALESCE(r1.responders,0) AS responders,
        COALESCE(r2.responders_target,0) AS responders_target
    FROM pop_sm p CROSS JOIN vintage_days v
    LEFT JOIN resp_d r1 ON r1.wave_dt=p.wave_dt AND r1.strategy_arm=p.strategy_arm
        AND r1.model_arm=p.model_arm AND r1.test_group=p.test_group AND r1.vintage_day=v.vintage_day
    LEFT JOIN resp_t r2 ON r2.wave_dt=p.wave_dt AND r2.strategy_arm=p.strategy_arm
        AND r2.model_arm=p.model_arm AND r2.test_group=p.test_group AND r2.vintage_day=v.vintage_day
),

/* Same thing rolled up across model arm into an "Overall" line, so I get
   a strategy-level total next to the model breakdown. */
overall_model AS (
    SELECT p.wave_dt,p.strategy_arm,CAST('Overall' AS VARCHAR(50)) AS model_arm,p.test_group,
        v.vintage_day,p.total_population,
        COALESCE(SUM(d.responders),0) AS responders,
        COALESCE(SUM(d.responders_target),0) AS responders_target
    FROM pop_s p CROSS JOIN vintage_days v
    LEFT JOIN detailed_by_model d ON d.wave_dt=p.wave_dt AND d.strategy_arm=p.strategy_arm
        AND d.test_group=p.test_group AND d.vintage_day=v.vintage_day
    GROUP BY 1,2,4,5,6
),

final_grain AS (
    SELECT * FROM detailed_by_model
    UNION ALL
    SELECT * FROM overall_model
)

/* Output. The window SUMs turn daily counts into a running cumulative
   curve within each segment, ordered by vintage day. */
SELECT wave_dt,strategy_arm,model_arm,test_group,vintage_day,total_population,responders,responders_target,
    SUM(responders) OVER (PARTITION BY wave_dt,strategy_arm,model_arm,test_group
        ORDER BY vintage_day ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS responders_cum,
    SUM(responders_target) OVER (PARTITION BY wave_dt,strategy_arm,model_arm,test_group
        ORDER BY vintage_day ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS responders_target_cum
FROM final_grain
ORDER BY wave_dt,strategy_arm,model_arm,test_group,vintage_day;