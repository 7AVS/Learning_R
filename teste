   AUH_P2 RECONCILIATION WORKBOOK  (Teradata)
   ---------------------------------------------------------------------
   PROBLEM: vintage "responders_target_cum" (~65 Test) is ~13x lower than
   the summary "resp_cnts" (~870 Test), even though POPULATION reconciles
   to within single digits. The whole gap is in HOW A RESPONDER IS COUNTED.

     - Summary   = account CURRENTLY OWNS the matching product
                   (captr_dt > 4/30). A STOCK. No timing vs treatment.
     - Vintage   = account ACQUIRED the product within the 4/30-5/31
                   window AND within 30 days of treatment (uses DT_CRV).
                   A FLOW.

   The decisive unknown: which column is the REAL acquisition date,
   DT_CRV or captr_dt? Run SECTION 1 and SECTION 2 to find out, then
   use SECTION 4 if DT_CRV turns out to be a creation date.

   Run each SECTION on its own.
   ===================================================================== */


/* =====================================================================
   SECTION 0  --  THE SUMMARY (reference only, this is the high number)
   ===================================================================== */
select a.TST_GRP_CD,
       count(*) as lead_cnts,
       sum(case when (b.acct_no is not null) then 1 else 0 end) as resp_cnts
from (
        select TST_GRP_CD,
               substr(tactic_decisn_vrb_info, 21, 3) as prod_cd,
               CAST(TACTIC_EVNT_ID AS DECIMAL(20,0)) AS acct_no
        from DG6V01.tactic_evnt_ip_ar_hist
        where tactic_id = '2026119AUH'
     ) as a
left join (
        select acct_no, prod_cd
        from D3CV12A.ACCT_CRD_OWN_DLY_DELTA
        where CHG_DT = '9999/12/31'
          and RELATIONSHIP_CD = '2'
          and card_sts in ('A', '')
          and captr_dt > date '2026-04-30'
     ) as b
  on a.acct_no = b.acct_no
 and a.prod_cd = b.prod_cd
group by 1
order by 1;


